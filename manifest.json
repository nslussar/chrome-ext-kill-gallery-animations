{
  "manifest_version": 3,
  "name": "chrome-ext-kill-gallery-animations",
  "version": "1.3",
  "description": "Disables fade, slide, and transition animations in Lightbox2, bxSlider, and ModuloBox galleries.",
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["injector.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lightbox-override.css", "bxslider-override.css", "modulobox-override.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
